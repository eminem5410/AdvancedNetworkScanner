<Window x:Class="AdvancedScanner.App.Views.DeviceActionWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Acciones de Dispositivo" Height="550" Width="400"
        Background="#2D2D2D" ResizeMode="NoResize" WindowStartupLocation="CenterOwner"
        Foreground="White" WindowStyle="SingleBorderWindow">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="20">
            
            <!-- Información del Dispositivo -->
            <TextBlock Text="DISPOSITIVO SELECCIONADO" FontSize="14" FontWeight="Bold" Foreground="#00E5FF" Margin="0,0,0,15"/>

            <Grid Margin="0,0,0,20">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                
                <TextBlock Grid.Row="0" Text="IP:" Foreground="#AAAAAA"/>
                <TextBlock Grid.Row="0" Text="{Binding IP}" FontWeight="Bold" HorizontalAlignment="Right" Margin="0,0,0,5"/>

                <TextBlock Grid.Row="1" Text="Host Name:" Foreground="#AAAAAA"/>
                <TextBlock Grid.Row="1" Text="{Binding HostName}" FontWeight="Bold" HorizontalAlignment="Right" Margin="0,0,0,5"/>

                <TextBlock Grid.Row="2" Text="MAC:" Foreground="#AAAAAA"/>
                <TextBlock Grid.Row="2" Text="{Binding MACAddress}" FontWeight="Bold" HorizontalAlignment="Right" Margin="0,0,0,5"/>

                <TextBlock Grid.Row="3" Text="Tipo:" Foreground="#AAAAAA"/>
                <TextBlock Grid.Row="3" Text="{Binding DeviceType}" FontWeight="Bold" HorizontalAlignment="Right"/>
            </Grid>

            <Separator Margin="0,0,0,20"/>

            <!-- Botones de Acción -->
            <TextBlock Text="ACCIONES DISPONIBLES" FontSize="12" FontWeight="Bold" Foreground="#CCCCCC" Margin="0,0,0,10"/>

            <Button Content="Abrir en Navegador Web" Click="OpenBrowser_Click" Height="30" Margin="0,0,0,5" Background="#007ACC" Foreground="White"/>
            <Button Content="Abrir Carpetas Compartidas (SMB)" Click="OpenSMB_Click" Height="30" Margin="0,0,0,5" Background="#007ACC" Foreground="White"/>
            <Button Content="Enviar Magic Packet (Wake-on-LAN)" Click="WakeOnLan_Click" Height="30" Margin="0,0,0,5" Background="#FFA500" Foreground="Black" FontWeight="Bold"/>
            <Button Content="Conexión Remota (RDP)" Click="OpenRDP_Click" Height="30" Margin="0,0,0,5" Background="#D9534F" Foreground="White"/>
            <Button Content="Copiar IP al Portapapeles" Click="CopyIP_Click" Height="30" Margin="0,0,0,5" Background="#555555" Foreground="White"/>
            
            <!-- SECCIÓN NUEVA: ESCANEO DE PUERTOS -->
            <Separator Margin="0,15,0,10"/>
            <TextBlock Text="ESCANEO DE PUERTOS" FontSize="12" FontWeight="Bold" Foreground="#00E5FF" Margin="0,0,0,10"/>
            
            <Button Name="BtnScanPorts" Content="Escanear Puertos Comunes" Click="ScanPorts_Click" Height="30" Margin="0,0,0,10" Background="#2E8B57" Foreground="White" FontWeight="Bold"/>
            
            <TextBlock Text="Puertos Abiertos Detectados:" Foreground="#CCCCCC" FontSize="11" Margin="0,0,0,5"/>
            
            <ListBox Name="PortsListBox" Height="120" Background="#1E1E1E" BorderBrush="#555" Foreground="#00FF00" FontFamily="Consolas" FontSize="11">
                <!-- Aquí aparecerán los resultados -->
            </ListBox>

            <!-- Botón Cerrar -->
            <Button Content="Cerrar" Click="Close_Click" Height="30" Margin="0,20,0,0" Background="#333333" Foreground="#CCCCCC" BorderThickness="1" BorderBrush="#555"/>

        </StackPanel>
    </ScrollViewer>
</Window>